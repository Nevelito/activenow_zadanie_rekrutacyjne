<%= turbo_frame_tag "modal" do %>
  <div data-controller="modal" class="fixed inset-0 z-50 flex items-center justify-center">
    <div data-action="click->modal#hideModal" class="absolute inset-0 bg-black/20"></div>
    <%= render Tasks::FormComponent.new(task: @task, project: @project, title: "Edytuj zadanie") %>
  </div>
<% end %>
