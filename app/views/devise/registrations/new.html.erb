<div class="flex flex-col items-center justify-center w-full h-screen bg-[#e2eef5]">
  <div class="flex">
    <%= image_tag "activenow-logo.png", class: "w-48 h-48 object-contain" %>
  </div>

  <div class="flex flex-col items-center justify-center gap-y-6 w-1/3 p-8 bg-white rounded-lg shadow-lg">
    <h2 class="text-3xl font-semibold text-gray-700">Jak miło, że chcesz do nas dołączyć!</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="flex flex-col w-full">
        <%= f.label :email, class: "mb-1 text-gray-600" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
                          class: "border border-gray-300 rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>

      <div class="flex flex-col w-full mt-4">
        <%= f.label :password, "Hasło", class: "mb-1 text-gray-600" %>
        <% if @minimum_password_length %>
          <em class="text-sm text-gray-500">(minimalnie <%= @minimum_password_length %> znaków)</em>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
                             class: "border border-gray-300 rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 mt-1" %>
      </div>

      <div class="flex flex-col w-full mt-4">
        <%= f.label :password_confirmation, "Powtórz hasło", class: "mb-1 text-gray-600" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
                             class: "border border-gray-300 rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>

      <div class="w-full mt-6">
        <%= f.submit "Zarejestruj się", class: "w-full bg-gradient-to-r from-[#7acbd5] to-[#45c7f2] text-white py-2 rounded-lg transition-colors duration-200 hover:from-[#5fb1cd] hover:to-[#349fdb]" %>
      </div>
    <% end %>

    <div class="flex flex-row gap-x-6 mt-4 text-sm text-[#47c8f1]">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
