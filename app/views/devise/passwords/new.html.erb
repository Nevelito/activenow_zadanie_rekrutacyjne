<div class="flex flex-col items-center justify-center w-full h-screen bg-[#e2eef5]">
  <div class="flex">
    <%= image_tag "activenow-logo.png", class: "w-48 h-48 object-contain" %>
  </div>

  <div class="flex flex-col items-center justify-center gap-y-6 w-1/3 p-8 bg-white rounded-lg shadow-lg">
    <div>
      <h2 class="text-3xl font-semibold text-gray-700">Zapomniałeś hasła?</h2>
      <h2 class="text-3xl font-semibold text-gray-700">Żaden problem!</h2>
    </div>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="flex flex-col w-full">
        <%= f.label :email, class: "mb-1 text-gray-600" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
                          class: "border border-gray-300 rounded px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400" %>
      </div>

      <div class="w-full mt-6">
        <%= f.submit "Zresetuj hasło",
                     class: "w-full bg-gradient-to-r from-[#7acbd5] to-[#45c7f2] text-white py-2 rounded-lg transition-colors duration-200 hover:from-[#5fb1cd] hover:to-[#349fdb]" %>
      </div>
    <% end %>

    <div class="flex flex-row gap-x-6 mt-4 text-sm text-[#47c8f1]">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
