<div class="flex justify-between items-center p-6">
  <h1 class="text-2xl font-bold">Zadania</h1>
  <%= link_to new_project_task_path(@project),
              data: { turbo_frame: "modal" },
              class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition" do %>
    Dodaj zadanie
  <% end %>
</div>
<div data-controller="kanban" class="grid grid-cols-3 gap-6 w-full h-screen p-6 pt-0">
  <%= render(Projects::ColComponent.new(project: @project, title: "Do zrobienia", status: "todo")) %>
  <%= render(Projects::ColComponent.new(project: @project, title: "W trakcie realizacji", status: "in_progress")) %>
  <%= render(Projects::ColComponent.new(project: @project, title: "Zakończone", status: "done")) %>
</div>
