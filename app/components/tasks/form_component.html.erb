<div class="bg-white rounded-xl shadow-lg w-96 p-6 z-10">
  <div class="flex justify-center mb-4">
    <%= image_tag "activenow-logo.png", class: "w-16 h-16 object-contain" %>
  </div>
  <h2 class="text-xl font-bold text-gray-800 mb-4"><%= @title %></h2>
  <%= form_with(model: [@project, @task], local: true, data: { turbo_frame: "_top" }, html: { class: "w-full" }) do |f| %>
    <div class="flex flex-col gap-3">
      <%= f.label :title, "Nazwa zadania" %>
      <%= f.text_field :title, placeholder: "Wpisz nazwę zadania", class: "w-full border border-neutral-300 h-12 py-2 px-3 rounded-lg focus:outline-none" %>
    </div>

    <div class="flex flex-col gap-3 mt-4">
      <%= f.label :description, "Opis" %>
      <%= f.text_area :description, placeholder: "Opis zadania", rows: 4, class: "w-full border border-neutral-300 py-2 px-3 rounded-lg focus:outline-none" %>
    </div>

    <div class="flex flex-col gap-3 mt-4">
      <%= f.label :due_date, "Termin" %>
      <%= f.date_field :due_date, class: "w-full border border-neutral-300 py-2 px-3 rounded-lg focus:outline-none" %>
    </div>

    <div class="flex flex-col gap-3 mt-4">
      <%= f.label :status, "Status" %>
      <%= f.select :status, Task.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "w-full border border-neutral-300 py-2 px-3 rounded-lg focus:outline-none" %>
    </div>

    <div class="flex w-full justify-end mt-6 space-x-3">
      <%= button_tag "Anuluj", type: "button", data: { action: "modal#hideModal" }, class: "bg-red-700 text-white px-4 py-2 rounded-lg" %>
      <%= f.submit @task.persisted? ? "Zapisz zmiany" : "Dodaj zadanie", class: "bg-green-700 text-white px-4 py-2 rounded-lg" %>
    </div>
  <% end %>
</div>
